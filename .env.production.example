# =============================================================================
# Drink-UX Production Environment Variables
# Copy to .env and fill in values before deploying.
# NEVER commit the actual .env file to version control.
# =============================================================================

# --- Database ---
# Railway PostgreSQL: auto-provided as $DATABASE_URL after adding Postgres plugin
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/drinkux

# --- API Server ---
NODE_ENV=production
PORT=3001

# --- Security ---
# Generate with: openssl rand -base64 32
SESSION_SECRET=CHANGE_ME_generate_with_openssl_rand_base64_32
# Must be exactly 32 characters for AES-256 encryption of POS tokens
ENCRYPTION_KEY=CHANGE_ME_exactly_32_characters!!

# --- CORS ---
# Comma-separated list of allowed frontend origins
CORS_ORIGIN=https://drink-ux.com,https://admin.drink-ux.com

# --- Square ---
# From Square Developer Dashboard (https://developer.squareup.com)
SQUARE_ENVIRONMENT=production
SQUARE_APPLICATION_ID=sq0idp-XXXXXXXXXXXXXXXXXXXXXXXX
SQUARE_APPLICATION_SECRET=sq0csp-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
SQUARE_WEBHOOK_SIGNATURE_KEY=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
# OAuth redirect URI (must match Square app settings exactly):
#   https://api.drink-ux.com/api/onboarding/square-callback
# Add this to Square app → OAuth → Redirect URLs

# --- POS Token Encryption ---
# 32-character key for encrypting stored POS OAuth tokens
POS_TOKEN_ENCRYPTION_KEY=CHANGE_ME_exactly_32_characters!!
