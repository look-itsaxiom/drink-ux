{
  "name": "drink-ux",
  "version": "1.0.0",
  "description": "SaaS app for coffee businesses with custom drink builder and POS integration",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspace=@drink-ux/shared && npm run build --workspaces",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "lint": "eslint packages/shared/src packages/api/src packages/admin/src packages/mobile/src",
    "test": "npm run test --workspaces",
    "dev": "npm run dev --workspaces --if-present"
  },
  "keywords": [
    "pos",
    "coffee",
    "drink-builder",
    "saas",
    "ionic",
    "react"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.0.3",
    "typescript": "^5.3.0",
    "typescript-eslint": "^8.57.0"
  }
}