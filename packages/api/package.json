{
  "name": "@drink-ux/api",
  "version": "1.0.0",
  "description": "TypeScript API backend for Drink-UX",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "ts-node src/index.ts",
    "start": "node dist/index.js",
    "test": "node --no-webstorage ../../node_modules/jest/bin/jest.js",
    "test:watch": "node --no-webstorage ../../node_modules/jest/bin/jest.js --watch",
    "test:coverage": "node --no-webstorage ../../node_modules/jest/bin/jest.js --coverage",
    "test:ci": "node --no-webstorage ../../node_modules/jest/bin/jest.js --ci --coverage --watchAll=false",
    "test:verbose": "node --no-webstorage ../../node_modules/jest/bin/jest.js --verbose"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@drink-ux/shared": "^1.0.0",
    "bcrypt": "^5.1.1",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.5.0",
    "square": "^43.2.1"
  },
  "devDependencies": {
    "@prisma/client": "^6.18.0",
    "@types/bcrypt": "^5.0.2",
    "@types/cookie-parser": "^1.4.7",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^30.0.0",
    "@types/node": "^20.10.0",
    "@types/supertest": "^6.0.3",
    "jest": "^29.7.0",
    "jest-mock-extended": "^4.0.0",
    "prisma": "^6.18.0",
    "prisma-mock": "^0.12.2",
    "supertest": "^7.1.4",
    "ts-jest": "^29.4.4",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.0"
  }
}
