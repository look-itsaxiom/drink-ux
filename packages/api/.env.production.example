# Production environment variables for Drink-UX API
# Deploy these to Railway → service → Variables
# DO NOT commit actual values to the repository

# Server
NODE_ENV=production
PORT=3001

# Database — set automatically by Railway PostgreSQL plugin
# DATABASE_URL=postgresql://user:password@host:5432/drink_ux

# Session & encryption (generate with: openssl rand -base64 32)
SESSION_SECRET=
ENCRYPTION_KEY=

# Square POS — get from https://developer.squareup.com/apps
SQUARE_APPLICATION_ID=
SQUARE_APPLICATION_SECRET=
SQUARE_ENVIRONMENT=production
SQUARE_OAUTH_CALLBACK_URL=https://api.drink-ux.com/api/pos/oauth/callback
SQUARE_WEBHOOK_SIGNATURE_KEY=

# CORS — list all frontend origins
CORS_ORIGIN=https://app.drink-ux.com,https://admin.drink-ux.com

# Error tracking — get DSN from Sentry project settings
SENTRY_DSN=
