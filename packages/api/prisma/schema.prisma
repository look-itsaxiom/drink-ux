// Prisma schema for Drink-UX
// Source of truth for coffee shop menu management

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// =============================================================================
// ENUMS
// =============================================================================

enum AccountState {
  ONBOARDING       // In wizard, not complete
  SETUP_COMPLETE   // Finished onboarding, no subscription
  ACTIVE           // Subscribed, accepting orders
  PAUSED           // Subscription lapsed, storefront disabled
  EJECTED          // Disconnected, data preserved
}

enum POSProvider {
  SQUARE
  TOAST
  CLOVER
}

enum TemperatureConstraint {
  HOT_ONLY
  ICED_ONLY
  BOTH
}

enum ModifierType {
  MILK
  SYRUP
  TOPPING
}

enum CupSize {
  SMALL
  MEDIUM
  LARGE
}

enum OrderStatus {
  PENDING     // Customer submitted, awaiting POS confirmation
  CONFIRMED   // POS accepted, payment complete
  PREPARING   // Business marked as in-progress
  READY       // Ready for pickup
  COMPLETED   // Customer picked up, order closed
  CANCELLED   // Cancelled by customer or business
  FAILED      // POS rejected or payment failed
}

enum SyncStatus {
  IDLE        // No sync in progress
  SYNCING     // Sync is currently running
  SUCCESS     // Last sync completed successfully
  ERROR       // Last sync failed
}

// =============================================================================
// USER & BUSINESS
// =============================================================================

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  passwordHash  String
  name          String?
  emailVerified Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Email verification
  emailVerificationToken    String?   @unique
  emailVerificationExpires  DateTime?

  // Password reset
  passwordResetToken        String?   @unique
  passwordResetExpires      DateTime?

  // Relations
  businesses    Business[]
  sessions      Session[]
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  // Relations
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Business {
  id                 String       @id @default(cuid())
  name               String
  slug               String       @unique
  ownerId            String

  // Contact info
  contactEmail       String?
  contactPhone       String?

  // Account state
  accountState       AccountState @default(ONBOARDING)
  subscriptionStatus String?      // Square subscription ID or status

  // Theme (stored as JSON)
  theme              Json?        // { primaryColor, secondaryColor, backgroundColor, logoUrl }

  // POS Connection
  posProvider        POSProvider?
  posAccessToken     String?      // Encrypted OAuth token
  posRefreshToken    String?      // Encrypted refresh token
  posMerchantId      String?
  posLocationId      String?
  posLastSyncAt      DateTime?

  // Catalog Sync Status
  syncStatus         SyncStatus   @default(IDLE)
  lastSyncedAt       DateTime?    // Last successful sync timestamp
  lastSyncError      String?      // Error message from last failed sync

  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt

  // Relations
  owner              User         @relation(fields: [ownerId], references: [id])
  categories         Category[]
  bases              Base[]
  modifiers          Modifier[]
  presets            Preset[]
  orders             Order[]
  syncHistory        SyncHistory[]
}

// =============================================================================
// CATALOG
// =============================================================================

model Category {
  id           String   @id @default(cuid())
  businessId   String
  name         String
  displayOrder Int      @default(0)
  color        String?  // Hex color for UI
  icon         String?  // Icon identifier
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relations
  business     Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  bases        Base[]

  @@unique([businessId, name])
}

model Base {
  id                    String                @id @default(cuid())
  businessId            String
  categoryId            String
  name                  String
  basePrice             Float
  temperatureConstraint TemperatureConstraint @default(BOTH)
  available             Boolean               @default(true)

  // Visual properties for DrinkVisualizer
  visualColor           String?
  visualOpacity         Float                 @default(1.0)

  // POS mapping (set after sync)
  posItemId             String?

  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt

  // Relations
  business              Business              @relation(fields: [businessId], references: [id], onDelete: Cascade)
  category              Category              @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  presets               Preset[]

  @@unique([businessId, name])
}

model Modifier {
  id                   String       @id @default(cuid())
  businessId           String
  type                 ModifierType
  name                 String
  price                Float        @default(0)
  available            Boolean      @default(true)

  // Visual properties for DrinkVisualizer
  visualColor          String?
  visualLayerOrder     Int          @default(0)
  visualAnimationType  String?      // "foam", "drizzle", "sparkle", etc.

  // POS mapping (set after sync)
  posModifierId        String?

  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @updatedAt

  // Relations
  business             Business     @relation(fields: [businessId], references: [id], onDelete: Cascade)
  presetModifiers      PresetModifier[]

  @@unique([businessId, type, name])
}

model Preset {
  id          String    @id @default(cuid())
  businessId  String
  name        String
  baseId      String
  defaultSize CupSize   @default(MEDIUM)
  defaultHot  Boolean   @default(true)
  price       Float
  available   Boolean   @default(true)
  imageUrl    String?

  // POS mapping (set after sync)
  posItemId   String?

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // Relations
  business    Business  @relation(fields: [businessId], references: [id], onDelete: Cascade)
  base        Base      @relation(fields: [baseId], references: [id], onDelete: Cascade)
  modifiers   PresetModifier[]

  @@unique([businessId, name])
}

// Join table for Preset <-> Modifier (many-to-many)
model PresetModifier {
  id         String   @id @default(cuid())
  presetId   String
  modifierId String

  // Relations
  preset     Preset   @relation(fields: [presetId], references: [id], onDelete: Cascade)
  modifier   Modifier @relation(fields: [modifierId], references: [id], onDelete: Cascade)

  @@unique([presetId, modifierId])
}

// =============================================================================
// ORDERS
// =============================================================================

model Order {
  id            String      @id @default(cuid())
  businessId    String

  // Order identifiers
  orderNumber   String      // Human-readable (e.g., "A42")
  pickupCode    String      // Short code for pickup (e.g., "7X2K")

  // POS reference (set after submission)
  posOrderId    String?
  posStatus     String?     // Raw status from POS

  // Customer info (guest checkout)
  customerName  String
  customerEmail String?
  customerPhone String?

  // Order state
  status        OrderStatus @default(PENDING)

  // Pricing
  subtotal      Float
  tax           Float
  total         Float

  // Notes
  notes         String?

  // Timestamps
  estimatedReadyAt DateTime?
  completedAt      DateTime?
  cancelledAt      DateTime?
  cancelReason     String?

  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  // Relations
  business      Business    @relation(fields: [businessId], references: [id], onDelete: Cascade)
  items         OrderItem[]

  @@index([businessId, status])
  @@index([businessId, pickupCode])
  @@unique([businessId, orderNumber])
}

model OrderItem {
  id          String  @id @default(cuid())
  orderId     String

  // Reference to base item
  baseId      String

  // Snapshot of what was ordered (denormalized for history)
  name        String  // e.g., "Vanilla Oat Latte"
  quantity    Int     @default(1)
  size        String  // SMALL, MEDIUM, LARGE
  temperature String  // HOT, ICED

  // Pricing
  unitPrice   Float
  totalPrice  Float

  // Modifiers as JSON array: [{ id, name, price }]
  modifiers   String  @default("[]")  // JSON stored as string for SQLite compatibility

  notes       String?

  createdAt   DateTime @default(now())

  // Relations
  order       Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

// =============================================================================
// SYNC HISTORY
// =============================================================================

model SyncHistory {
  id                 String      @id @default(cuid())
  businessId         String

  // Sync details
  status             SyncStatus
  startedAt          DateTime    @default(now())
  completedAt        DateTime?

  // Counts
  itemsCreated       Int         @default(0)
  itemsUpdated       Int         @default(0)
  itemsDeactivated   Int         @default(0)
  modifiersCreated   Int         @default(0)
  modifiersUpdated   Int         @default(0)

  // Error info
  errorMessage       String?
  errorDetails       Json?       // Detailed error info including failed items

  // Relations
  business           Business    @relation(fields: [businessId], references: [id], onDelete: Cascade)
}
