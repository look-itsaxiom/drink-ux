# API Environment Variables

# Server
PORT=3001

# Database
DATABASE_URL="file:./dev.db"

# =============================================================================
# Square POS Integration
# =============================================================================
# Get these from https://developer.squareup.com/apps
# See docs/SQUARE_SANDBOX_SETUP.md for detailed setup instructions

# Square Application Credentials (from Square Developer Dashboard)
SQUARE_APPLICATION_ID=sandbox-sq0idb-XXXXXXXXXXXXXXXXXXXXXXXX
SQUARE_APPLICATION_SECRET=sandbox-sq0csb-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Environment: 'sandbox' for testing, 'production' for live
SQUARE_ENVIRONMENT=sandbox

# OAuth callback URL (must match the one configured in Square Developer Dashboard)
# For local development:
SQUARE_OAUTH_CALLBACK_URL=http://localhost:3001/api/pos/oauth/callback
